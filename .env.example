# VHS API base URL (discover which works)
VHS_BASE_URL=https://vhs.testnet.postfiat.org

# Local validator RPC
LOCAL_NODE_RPC=http://127.0.0.1:5005

# Additional validator RPCs to query (comma-separated, port 5005)
# These are attempted but failures are non-fatal
EXTRA_NODE_RPCS=http://96.30.195.78:5005,http://207.244.252.247:5005,http://89.117.22.89:5005,http://5.189.161.208:5005,http://128.140.98.29:5005,http://5.78.182.64:5005,http://144.202.31.74:5005

# Polling interval in seconds
POLL_INTERVAL_SECONDS=300

# SQLite database path
DATABASE_PATH=data/scores.db

# API host/port
API_HOST=0.0.0.0
API_PORT=8000

# Scoring methodology version
METHODOLOGY_VERSION=1.0.0

# Logging
LOG_LEVEL=INFO

# Manual node-to-validator key mappings (comma-separated node_key:master_key pairs)
# Use this when automatic correlation can't map a topology node to its validator
# MANUAL_KEY_MAPPINGS=n9NodeKey1:nHMasterKey1,n9NodeKey2:nHMasterKey2
